#!/usr/bin/env bash
# Run an AppImage inside a generic GUI-runtime podman container.
#
# Strategy:
#   - One image (built once or pulled from a registry) provides the GUI runtime libs.
#   - The AppImage is extracted to a host cache and bind-mounted at /opt/app.
#   - Per-app persistent state lives in ~/.config/app-image-podman/<name>/ and is
#     bind-mounted as the container's $HOME, so wherever the app writes under
#     $HOME ends up captured in one tree per app.
set -euo pipefail

IMAGE="${APP_IMAGE_PODMAN_IMAGE:-ghcr.io/gilesknap/appimage-pod:latest}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CACHE_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}/app-image-podman"
CONFIG_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}/app-image-podman"

usage() {
    cat <<EOF
Usage: $0 [--name NAME] [--rebuild-image] [--re-extract] <AppImage|name> [args...]
       $0 --show
       $0 -h | --help

Run an AppImage inside a generic GUI-runtime podman container, with X11
forwarding and per-app persistent state. The runtime image provides the
GUI libs; AppImages are extracted to a host cache and bind-mounted at
/opt/app, so one image works for any AppImage.

Positional:
  <AppImage|name>   Either a path to an .AppImage file (extracted on first
                    use, then cached), or a bare name that already exists in
                    the cache (e.g. "UaExpert"). Once an app has been run
                    once from a file, the original AppImage can be deleted
                    and re-launched by name.
  args...           Extra arguments passed through to the AppImage entrypoint.

Flags:
  --name NAME       Override the derived app name (used for the cache dir,
                    config dir, and container name). Default: derived from
                    the AppImage filename, or in name mode from the
                    positional argument.
  --rebuild-image   Force rebuild of the runtime image from ./Containerfile
                    (only works when run from a clone of the repo).
  --re-extract      Force re-extraction of the AppImage (only valid when
                    launching from a file path).
  --show            List all cached AppImages and exit.
  -h, --help        Show this help and exit.

Paths:
  Cache:   $CACHE_ROOT/<name>/app-root/   (extracted AppImage tree)
  Config:  $CONFIG_ROOT/<name>/           (mounted as the container's \$HOME)

Env:
  APP_IMAGE_PODMAN_IMAGE  Override the runtime image reference.
                          Default: ghcr.io/gilesknap/appimage-pod:latest
  XDG_CACHE_HOME          Cache root override (default: ~/.cache).
  XDG_CONFIG_HOME         Config root override (default: ~/.config).
  DISPLAY                 X server to forward (default: :0).

Examples:
  $0 ~/Downloads/UaExpert-2.0.1-x86_64.AppImage
  $0 UaExpert                       # re-launch from cache
  $0 --name myapp ~/some.AppImage   # override the derived name
  $0 --show                         # list cached apps
EOF
    exit "${1:-1}"
}

show_cached() {
    if [[ ! -d "$CACHE_ROOT" ]]; then
        echo "No cache directory at $CACHE_ROOT"
        return 0
    fi
    local found=0
    for d in "$CACHE_ROOT"/*/; do
        [[ -d "${d}app-root" ]] || continue
        found=1
        printf '%s\n' "$(basename "$d")"
    done
    if [[ "$found" -eq 0 ]]; then
        echo "No cached AppImages in $CACHE_ROOT"
    fi
}

NAME=""
REBUILD_IMAGE=0
RE_EXTRACT=0
APPIMAGE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)          NAME="$2"; shift 2 ;;
        --rebuild-image) REBUILD_IMAGE=1; shift ;;
        --re-extract)    RE_EXTRACT=1; shift ;;
        --show)          show_cached; exit 0 ;;
        -h|--help)       usage 0 ;;
        --)              shift; APPIMAGE="${1:-}"; shift || true; break ;;
        -*)              echo "Unknown flag: $1" >&2; usage ;;
        *)               APPIMAGE="$1"; shift; break ;;
    esac
done

[[ -n "$APPIMAGE" ]] || usage

# The positional argument is either a path to an .AppImage file or a bare
# name referring to a previously-extracted app in the cache.
FROM_CACHE=0
if [[ -f "$APPIMAGE" ]]; then
    APPIMAGE="$(realpath "$APPIMAGE")"
elif [[ "$APPIMAGE" != */* ]]; then
    FROM_CACHE=1
    [[ -z "$NAME" ]] && NAME="$APPIMAGE"
else
    echo "No such AppImage file: $APPIMAGE" >&2
    usage
fi

# Derive a clean app name from the filename if not provided.
if [[ -z "$NAME" ]]; then
    NAME="${APPIMAGE##*/}"
    NAME="${NAME%.AppImage}"
    NAME="${NAME%-x86_64}"
    NAME="${NAME%-amd64}"
    NAME="${NAME%-X64}"
    NAME="${NAME%-linux*}"
    NAME="${NAME%-[0-9]*}"
fi

APP_CACHE="$CACHE_ROOT/$NAME"
APP_ROOT="$APP_CACHE/app-root"
APP_STAMP="$APP_CACHE/source.sha256"
APP_CONFIG="$CONFIG_ROOT/$NAME"

if [[ "$FROM_CACHE" -eq 1 && ! -d "$APP_ROOT" ]]; then
    echo "No cached app named '$NAME' at $APP_ROOT." >&2
    echo "Pass a path to an .AppImage file to extract it first." >&2
    exit 1
fi

if [[ "$FROM_CACHE" -eq 1 && "$RE_EXTRACT" -eq 1 ]]; then
    echo "--re-extract requires an AppImage file path, not a bare name." >&2
    exit 1
fi

mkdir -p "$APP_CACHE" "$APP_CONFIG"

# Acquire the runtime image: rebuild if requested, else use local copy if
# present, else try to pull, else fall back to a local build (only if a
# Containerfile sits next to the script — i.e. running from a clone, not curled).
build_local() {
    if [[ ! -f "$SCRIPT_DIR/Containerfile" ]]; then
        echo "Image $IMAGE is not available locally and pull failed." >&2
        echo "If you installed appimage-pod via curl, the registry may be unreachable" >&2
        echo "or the image not yet published. Otherwise clone the repo to build locally." >&2
        exit 1
    fi
    echo ">> Building $IMAGE from $SCRIPT_DIR/Containerfile" >&2
    podman build -t "$IMAGE" "$SCRIPT_DIR"
}

if [[ "$REBUILD_IMAGE" -eq 1 ]]; then
    build_local
elif ! podman image exists "$IMAGE"; then
    if podman pull "$IMAGE" >/dev/null 2>&1; then
        echo ">> Pulled $IMAGE" >&2
    else
        echo ">> Pull failed, falling back to local build" >&2
        build_local
    fi
fi

# Extract the AppImage to the cache, skipping if the source is unchanged or
# if we're launching by name (cache-only mode).
if [[ "$FROM_CACHE" -eq 0 ]]; then
    NEW_SHA="$(sha256sum "$APPIMAGE" | awk '{print $1}')"
    OLD_SHA="$(cat "$APP_STAMP" 2>/dev/null || true)"
    if [[ "$RE_EXTRACT" -eq 1 ]] || [[ ! -d "$APP_ROOT" ]] || [[ "$NEW_SHA" != "$OLD_SHA" ]]; then
        echo ">> Extracting $APPIMAGE to $APP_ROOT" >&2
        rm -rf "$APP_ROOT" "$APP_CACHE/.extract"
        mkdir -p "$APP_CACHE/.extract"
        cp "$APPIMAGE" "$APP_CACHE/.extract/app.AppImage"
        chmod +x "$APP_CACHE/.extract/app.AppImage"
        # Zero the AppImage Type-2 magic (bytes 8..10 = 'A','I',\x02) so the kernel
        # treats it as a plain ELF; otherwise hosts without binfmt_misc registration
        # (and all containers) refuse to exec it.
        dd if=/dev/zero of="$APP_CACHE/.extract/app.AppImage" \
            bs=1 count=3 seek=8 conv=notrunc status=none
        ( cd "$APP_CACHE/.extract" && ./app.AppImage --appimage-extract >/dev/null )
        mv "$APP_CACHE/.extract/squashfs-root" "$APP_ROOT"
        rm -rf "$APP_CACHE/.extract"
        echo "$NEW_SHA" > "$APP_STAMP"
    fi
fi

# Allow this user's local containers to talk to the X server.
if command -v xhost >/dev/null 2>&1; then
    xhost +SI:localuser:"$(id -un)" >/dev/null
fi

exec podman run --rm -it \
    --name "appimage-${NAME,,}" \
    --userns=keep-id \
    --network=host \
    -e DISPLAY="${DISPLAY:-:0}" \
    -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
    -v "${APP_ROOT}:/opt/app:ro" \
    -v "${APP_CONFIG}:/home/ua" \
    "$IMAGE" "$@"
