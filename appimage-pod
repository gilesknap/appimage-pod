#!/usr/bin/env bash
# Run an AppImage inside a generic GUI-runtime podman container.
#
# Strategy:
#   - One image (built once or pulled from a registry) provides the GUI runtime libs.
#   - The AppImage is extracted to a host cache and bind-mounted at /opt/app.
#   - Per-app persistent state lives in ~/.config/app-image-podman/<name>/ and is
#     bind-mounted as the container's $HOME, so wherever the app writes under
#     $HOME ends up captured in one tree per app.
#   - The container is run --privileged: this is for sharing the host runtime
#     with the AppImage, not for isolation. --privileged also surfaces every
#     host device under /dev so apps can reach the GPU, audio, USB, etc.
set -euo pipefail

IMAGE="${APP_IMAGE_PODMAN_IMAGE:-ghcr.io/gilesknap/appimage-pod:latest}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CACHE_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}/app-image-podman"
CONFIG_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}/app-image-podman"

usage() {
    cat <<EOF
Usage: $0 [--name NAME] [--rebuild-image] [--re-extract] <AppImage|URL|name> [args...]
       $0 --show
       $0 -h | --help

Run an AppImage inside a generic GUI-runtime podman container, with X11
forwarding and per-app persistent state. The runtime image provides the
GUI libs; AppImages are extracted to a host cache and bind-mounted at
/opt/app, so one image works for any AppImage.

Positional:
  <AppImage|URL|name>
                    One of:
                      - an http(s) URL (downloaded into the cache, then
                        extracted as if it were a local file),
                      - a path to a local .AppImage file (extracted on first
                        use, then cached), or
                      - a bare name that already exists in the cache
                        (e.g. "UaExpert").
                    Once an app has been run once from a file or URL, the
                    original is no longer needed — re-launch by name.
  args...           Extra arguments passed through to the AppImage entrypoint.

Flags:
  --name NAME       Override the derived app name (used for the cache dir,
                    config dir, and container name). Default: derived from
                    the AppImage filename, or in name mode from the
                    positional argument.
  --rebuild-image   Force rebuild of the runtime image from ./Containerfile
                    (only works when run from a clone of the repo).
  --re-extract      Force re-extraction of the AppImage (only valid when
                    launching from a file path or URL).
  --shell           Drop into a bash shell inside the runtime container
                    (overrides the AppRun entrypoint). Handy for debugging
                    missing libs, glibc versions, or X11 problems without
                    actually launching the GUI.
  --show            List all cached AppImages and exit.
  -h, --help        Show this help and exit.

Paths:
  Cache:   $CACHE_ROOT/<name>/app-root/   (extracted AppImage tree)
  Config:  $CONFIG_ROOT/<name>/           (mounted as the container's \$HOME)

Env:
  APP_IMAGE_PODMAN_IMAGE  Override the runtime image reference.
                          Default: ghcr.io/gilesknap/appimage-pod:latest
  XDG_CACHE_HOME          Cache root override (default: ~/.cache).
  XDG_CONFIG_HOME         Config root override (default: ~/.config).
  DISPLAY                 X server to forward (default: :0). For SSH X11
                          forwarding (DISPLAY=host:N.M), the host needs
                          'xauth' installed; the cookie is rewritten with
                          FamilyWild and mounted into the container.

Examples:
  $0 ~/Downloads/UaExpert-2.0.1-x86_64.AppImage
  $0 https://example.com/foo.AppImage   # fetch then run
  $0 UaExpert                           # re-launch from cache
  $0 --name myapp ~/some.AppImage       # override the derived name
  $0 --shell krita                      # drop into bash inside the runtime
  $0 --show                             # list cached apps
EOF
    exit "${1:-1}"
}

show_cached() {
    if [[ ! -d "$CACHE_ROOT" ]]; then
        echo "No cache directory at $CACHE_ROOT"
        return 0
    fi
    local found=0
    for d in "$CACHE_ROOT"/*/; do
        [[ -d "${d}app-root" ]] || continue
        found=1
        printf '%s\n' "$(basename "$d")"
    done
    if [[ "$found" -eq 0 ]]; then
        echo "No cached AppImages in $CACHE_ROOT"
    fi
}

NAME=""
REBUILD_IMAGE=0
RE_EXTRACT=0
SHELL_MODE=0
APPIMAGE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)          NAME="$2"; shift 2 ;;
        --rebuild-image) REBUILD_IMAGE=1; shift ;;
        --re-extract)    RE_EXTRACT=1; shift ;;
        --shell)         SHELL_MODE=1; shift ;;
        --show)          show_cached; exit 0 ;;
        -h|--help)       usage 0 ;;
        --)              shift; APPIMAGE="${1:-}"; shift || true; break ;;
        -*)              echo "Unknown flag: $1" >&2; usage ;;
        *)               APPIMAGE="$1"; shift; break ;;
    esac
done

[[ -n "$APPIMAGE" ]] || usage

# The positional argument can be:
#   1. an http(s) URL — downloaded into the cache, then treated as a file
#   2. a path to an .AppImage file — extracted on first use
#   3. a bare name — must already exist in the cache
FROM_CACHE=0
if [[ "$APPIMAGE" =~ ^https?:// ]]; then
    DOWNLOAD_DIR="$CACHE_ROOT/.downloads"
    mkdir -p "$DOWNLOAD_DIR"
    URL_BASENAME="${APPIMAGE##*/}"
    URL_BASENAME="${URL_BASENAME%%\?*}"
    [[ -z "$URL_BASENAME" ]] && URL_BASENAME="downloaded.AppImage"
    DOWNLOADED="$DOWNLOAD_DIR/$URL_BASENAME"
    echo ">> Downloading $APPIMAGE" >&2
    curl -fsSL --retry 3 -o "$DOWNLOADED" "$APPIMAGE"
    APPIMAGE="$DOWNLOADED"
elif [[ -f "$APPIMAGE" ]]; then
    APPIMAGE="$(realpath "$APPIMAGE")"
elif [[ "$APPIMAGE" != */* ]]; then
    FROM_CACHE=1
    [[ -z "$NAME" ]] && NAME="$APPIMAGE"
else
    echo "No such AppImage file: $APPIMAGE" >&2
    usage
fi

# Derive a clean app name from the filename if not provided.
if [[ -z "$NAME" ]]; then
    NAME="${APPIMAGE##*/}"
    NAME="${NAME%.AppImage}"
    NAME="${NAME%-x86_64}"
    NAME="${NAME%-amd64}"
    NAME="${NAME%-X64}"
    NAME="${NAME%-linux*}"
    NAME="${NAME%-[0-9]*}"
fi

APP_CACHE="$CACHE_ROOT/$NAME"
APP_ROOT="$APP_CACHE/app-root"
APP_STAMP="$APP_CACHE/source.sha256"
APP_CONFIG="$CONFIG_ROOT/$NAME"

if [[ "$FROM_CACHE" -eq 1 && ! -d "$APP_ROOT" ]]; then
    echo "No cached app named '$NAME' at $APP_ROOT." >&2
    echo "Pass a path to an .AppImage file to extract it first." >&2
    exit 1
fi

if [[ "$FROM_CACHE" -eq 1 && "$RE_EXTRACT" -eq 1 ]]; then
    echo "--re-extract requires an AppImage file path, not a bare name." >&2
    exit 1
fi

mkdir -p "$APP_CACHE" "$APP_CONFIG"

if ! command -v podman >/dev/null 2>&1; then
    echo "podman is not installed or not on \$PATH." >&2
    echo "Install it from https://podman.io/docs/installation (e.g." >&2
    echo "'sudo apt install podman' on Debian/Ubuntu) and try again." >&2
    exit 1
fi

# Acquire the runtime image: rebuild if requested, else use local copy if
# present, else try to pull, else fall back to a local build. The build
# context is whichever is available — a Containerfile next to the script
# (i.e. running from a clone) or a fresh tarball from codeload.
build_local() {
    local build_dir
    if [[ -f "$SCRIPT_DIR/Containerfile" ]]; then
        build_dir="$SCRIPT_DIR"
    else
        build_dir="$(mktemp -d)"
        trap 'rm -rf "$build_dir"' EXIT
        echo ">> Fetching Containerfile from codeload" >&2
        if ! curl -fsSL https://codeload.github.com/gilesknap/appimage-pod/tar.gz/refs/heads/main \
                | tar xz --strip-components=1 -C "$build_dir" appimage-pod-main/Containerfile; then
            echo "Could not fetch the Containerfile from codeload." >&2
            echo "Check your network, or clone the repo and run from there." >&2
            exit 1
        fi
    fi
    echo ">> Building $IMAGE from $build_dir/Containerfile" >&2
    podman build -t "$IMAGE" "$build_dir"
}

if [[ "$REBUILD_IMAGE" -eq 1 ]]; then
    build_local
elif ! podman image exists "$IMAGE"; then
    if podman pull "$IMAGE" >/dev/null 2>&1; then
        echo ">> Pulled $IMAGE" >&2
    else
        echo ">> Pull failed, falling back to local build" >&2
        build_local
    fi
fi

# Extract the AppImage to the cache, skipping if the source is unchanged or
# if we're launching by name (cache-only mode).
if [[ "$FROM_CACHE" -eq 0 ]]; then
    NEW_SHA="$(sha256sum "$APPIMAGE" | awk '{print $1}')"
    OLD_SHA="$(cat "$APP_STAMP" 2>/dev/null || true)"
    if [[ "$RE_EXTRACT" -eq 1 ]] || [[ ! -d "$APP_ROOT" ]] || [[ "$NEW_SHA" != "$OLD_SHA" ]]; then
        echo ">> Extracting $APPIMAGE to $APP_ROOT" >&2
        rm -rf "$APP_ROOT" "$APP_CACHE/.extract"
        mkdir -p "$APP_CACHE/.extract"
        cp "$APPIMAGE" "$APP_CACHE/.extract/app.AppImage"
        chmod +x "$APP_CACHE/.extract/app.AppImage"
        # Zero the AppImage Type-2 magic (bytes 8..10 = 'A','I',\x02) so the kernel
        # treats it as a plain ELF; otherwise hosts without binfmt_misc registration
        # (and all containers) refuse to exec it.
        dd if=/dev/zero of="$APP_CACHE/.extract/app.AppImage" \
            bs=1 count=3 seek=8 conv=notrunc status=none
        ( cd "$APP_CACHE/.extract" && ./app.AppImage --appimage-extract >/dev/null )
        mv "$APP_CACHE/.extract/squashfs-root" "$APP_ROOT"
        rm -rf "$APP_CACHE/.extract"
        echo "$NEW_SHA" > "$APP_STAMP"
    fi
fi

# X11 wiring. Two cases:
#   - Local display (DISPLAY=:N or unix:N): connect via /tmp/.X11-unix and
#     authorize this user's containers via xhost.
#   - Remote/TCP display (e.g. SSH X11 forwarding, DISPLAY=host:N.M):
#     --network=host gives the container access to localhost:6010 etc., but
#     it needs the MIT-MAGIC-COOKIE from ~/.Xauthority. Rewrite the cookie
#     with FamilyWild ('ffff') so it isn't tied to the host's hostname.
EFFECTIVE_DISPLAY="${DISPLAY:-:0}"
X11_ARGS=( -e DISPLAY="$EFFECTIVE_DISPLAY" )
if [[ "$EFFECTIVE_DISPLAY" == :* ]] || [[ "$EFFECTIVE_DISPLAY" == unix:* ]]; then
    X11_ARGS+=( -v /tmp/.X11-unix:/tmp/.X11-unix:rw )
    if command -v xhost >/dev/null 2>&1; then
        xhost +SI:localuser:"$(id -un)" >/dev/null 2>&1 || true
    fi
else
    if ! command -v xauth >/dev/null 2>&1; then
        echo "DISPLAY=$EFFECTIVE_DISPLAY looks like a TCP/forwarded X server," >&2
        echo "but 'xauth' is not installed on the host so I can't extract the" >&2
        echo "MIT-MAGIC-COOKIE. Install xauth (e.g. 'sudo dnf install xorg-x11-xauth')." >&2
        exit 1
    fi
    XAUTH_FILE="$APP_CACHE/.Xauthority"
    : > "$XAUTH_FILE"
    chmod 600 "$XAUTH_FILE"
    # FamilyWild entries match any hostname, so the container doesn't need to
    # share the host's hostname for the cookie to be accepted.
    xauth nlist "$EFFECTIVE_DISPLAY" | sed -e 's/^..../ffff/' \
        | xauth -f "$XAUTH_FILE" nmerge - 2>/dev/null
    if [[ ! -s "$XAUTH_FILE" ]]; then
        echo "Could not extract an X11 cookie for DISPLAY=$EFFECTIVE_DISPLAY." >&2
        echo "Is X11 forwarding actually enabled on this SSH session" >&2
        echo "(ssh -X / -Y, and 'X11Forwarding yes' on the server)?" >&2
        exit 1
    fi
    X11_ARGS+=(
        -v "$XAUTH_FILE:/tmp/.Xauthority:ro"
        -e XAUTHORITY=/tmp/.Xauthority
    )
fi

RUN_ARGS=(
    --rm -it
    --name "appimage-${NAME,,}"
    --privileged
    --userns=keep-id
    --network=host
    --ipc=host
    -e XDG_RUNTIME_DIR=/tmp/runtime-ua
    -e APPDIR=/opt/app
    "${X11_ARGS[@]}"
    -v "${APP_ROOT}:/opt/app:ro"
    -v "${APP_CONFIG}:/home/ua"
)

if [[ "$SHELL_MODE" -eq 1 ]]; then
    exec podman run "${RUN_ARGS[@]}" --entrypoint /bin/bash "$IMAGE" "$@"
fi

exec podman run "${RUN_ARGS[@]}" "$IMAGE" "$@"
